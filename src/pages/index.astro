---
export const prerender = true;
import Layout from '../layouts/Layout.astro'
import { useTranslations } from '../i18n/index'
import SiteHeader from '../components/sections/SiteHeader.astro'
import SectionHero from '../components/sections/SectionHero.astro'
import SectionLogos from '../components/sections/SectionLogos.astro'
import SectionServices from '../components/sections/SectionServices.astro'
import SectionIntegrations from '../components/sections/SectionIntegrations.astro'
import SectionAI from '../components/sections/SectionAI.astro'
// import SectionTestimonial from '../components/sections/SectionTestimonial.astro'
import SectionPartner from '../components/sections/SectionPartner.astro'
import SectionProcess from '../components/sections/SectionProcess.astro'
import SectionFounders from '../components/sections/SectionFounders.astro'
import SectionFAQ from '../components/sections/SectionFAQ.astro'
import SectionFinalCTA from '../components/sections/SectionFinalCTA.astro'
import SiteFooter from '../components/sections/SiteFooter.astro'

const lang = Astro.currentLocale ?? 'es'
const t = useTranslations(lang)
---
<Layout title="Be Partner Labs — Web performance partnerships" description={t.hero.eyebrow} lang={lang}>
  <SiteHeader t={t} lang={lang} />
  <main id="main-content">
    <SectionHero t={t}/>
    <SectionLogos t={t} />
    <SectionServices t={t} />
    <SectionAI t={t} />
    {/* <SectionTestimonial t={t} /> */}
    <SectionPartner t={t} />
    <SectionProcess t={t} />
    <SectionFounders t={t} />
    <SectionFAQ t={t} />
    <SectionIntegrations t={t} />
    <SectionFinalCTA t={t} lang={lang} />
  </main>
  <SiteFooter t={t} lang={lang} />
</Layout>
