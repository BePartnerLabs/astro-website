---
export const prerender = true;
import Layout from '../../layouts/Layout.astro'
import type { Translations } from '../../i18n/es'
import SiteHeader from '../../components/sections/SiteHeader.astro'
import SectionContact from '../../components/sections/SectionContact.astro'
import SiteFooter from '../../components/sections/SiteFooter.astro'
import { getCollection } from 'astro:content'

const lang = 'en'
const [pages, sections] = await Promise.all([
  getCollection('pagesEn'),
  getCollection('sectionsEn'),
])
const page = pages.find(p => p.id === 'contact')
const t = sections.find(s => s.id === 'contact')!.data as unknown as Translations
---
<Layout title={page?.data.title ?? 'Contact — Be Partner Labs'} description={page?.data.description} lang={lang}>
  <SiteHeader t={t} lang={lang} />
  <main>
    <SectionContact t={t} />
  </main>
  <SiteFooter t={t} lang={lang} />
</Layout>