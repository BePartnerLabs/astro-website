---
interface NavLink {
  href: string
  label: string
  active?: boolean
}
interface Props {
  logo?: string
  links?: NavLink[]
  class?: string
}
const { logo = 'BPL', links = [], class: className = '' } = Astro.props
---
<nav class={`bpl-nav ${className}`}>
  <a href="/" class="bpl-nav__logo">{logo}</a>
  {links.length > 0 && (
    <ul class="bpl-nav__links" role="list">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class={`bpl-nav__link${link.active ? ' bpl-nav__link--active' : ''}`}
            aria-current={link.active ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  )}
  <slot />
</nav>
