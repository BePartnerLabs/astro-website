---
interface Props {
  label?: string
  hint?: string
  placeholder?: string
  value?: string
  name?: string
  type?: string
  id?: string
  required?: boolean
  class?: string
}
const { label, hint, placeholder, value, name, type = 'text', id, required = false, class: className = '' } = Astro.props
const inputId = id ?? (label ? label.toLowerCase().replace(/\s+/g, '-') : undefined)
---
<div class={`bpl-input-wrap ${className}`}>
  {label && (
    <label class="bpl-input-label" for={inputId}>
      {label}
      {required && <span class="bpl-input-required" aria-hidden="true"> *</span>}
    </label>
  )}
  <input
    class="bpl-input"
    id={inputId}
    name={name}
    type={type}
    placeholder={placeholder}
    value={value}
    required={required}
  />
  {hint && <span class="bpl-input-hint">{hint}</span>}
</div>
