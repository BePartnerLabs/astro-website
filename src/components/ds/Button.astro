---
interface Props {
  variant?: 'primary' | 'secondary' | 'mint' | 'ghost'
  size?: 'sm' | 'md' | 'lg'
  href?: string
  type?: 'button' | 'submit' | 'reset'
  class?: string
}
const { variant = 'primary', size = 'md', href, type = 'button', class: className = '' } = Astro.props
const classes = ['bpl-btn', `bpl-btn--${variant}`, size !== 'md' ? `bpl-btn--${size}` : '', className]
  .filter(Boolean).join(' ')
---
{href
  ? <a href={href} class={classes}><slot /></a>
  : <button type={type} class={classes}><slot /></button>
}
