---
import type { Translations } from '../../i18n/es';
interface Props { t: Translations; }
const { t } = Astro.props;
---
<button
  id="theme-toggle"
  class="theme-toggle"
  aria-pressed="false"
  aria-label={t.theme.label}
  type="button"
>
  <!-- Sun icon (shown in dark mode → click to go light) -->
  <svg class="theme-toggle__sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="5"/>
    <line x1="12" y1="1" x2="12" y2="3"/>
    <line x1="12" y1="21" x2="12" y2="23"/>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
    <line x1="1" y1="12" x2="3" y2="12"/>
    <line x1="21" y1="12" x2="23" y2="12"/>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
  </svg>
  <!-- Moon icon (shown in light mode → click to go dark) -->
  <svg class="theme-toggle__moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<style>
.theme-toggle {
  --_size: var(--theme-toggle-size, 32px);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: var(--_size);
  height: var(--_size);
  padding: 0;
  background: none;
  border: 1px solid var(--bpl-line);
  border-radius: var(--bpl-radius-sm);
  color: var(--bpl-ink-2);
  cursor: pointer;
  transition: color var(--bpl-dur-fast) var(--bpl-ease-std), border-color var(--bpl-dur-fast) var(--bpl-ease-std);
}
.theme-toggle:hover { color: var(--bpl-ink); border-color: var(--bpl-ink-3); }
.theme-toggle:focus-visible { outline: 2px solid var(--bpl-focus); outline-offset: 2px; }

/* Show sun in dark mode, moon in light mode */
:global([data-theme="dark"]) .theme-toggle__sun  { display: block; }
:global([data-theme="dark"]) .theme-toggle__moon { display: none; }
:global([data-theme="light"]) .theme-toggle__sun  { display: none; }
:global([data-theme="light"]) .theme-toggle__moon { display: block; }

/* Default (no data-theme yet) — show sun */
.theme-toggle__sun  { display: block; }
.theme-toggle__moon { display: none; }
</style>

<script>
  const btn = document.getElementById('theme-toggle');
  if (btn) {
    const html = document.documentElement;
    const update = () => {
      const isDark = html.getAttribute('data-theme') === 'dark';
      btn.setAttribute('aria-pressed', isDark ? 'true' : 'false');
    };
    update();
    btn.addEventListener('click', () => {
      const current = html.getAttribute('data-theme');
      const next = current === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
      update();
    });
  }
</script>
