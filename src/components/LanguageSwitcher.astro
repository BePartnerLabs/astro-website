---
import { getRelativeLocaleUrl } from 'astro:i18n';

const { pathname } = Astro.url;
const currentLocale = Astro.currentLocale ?? 'es';

// Strip the locale prefix before building alternate URLs
const strippedPath = pathname.replace(/^\/(es|en)(\/|$)/, '/') || '/';

const esUrl = getRelativeLocaleUrl('es', strippedPath);
const enUrl = getRelativeLocaleUrl('en', strippedPath);
---

<nav aria-label="Language switcher">
  <a
    href={esUrl}
    aria-current={currentLocale === 'es' ? 'true' : undefined}
    lang="es"
  >ES</a>
  <span aria-hidden="true"> / </span>
  <a
    href={enUrl}
    aria-current={currentLocale === 'en' ? 'true' : undefined}
    lang="en"
  >EN</a>
</nav>
