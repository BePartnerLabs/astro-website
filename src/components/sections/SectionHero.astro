---
import type { Translations } from '../../i18n/es'
import Button from '../ds/Button.astro'
import BPLMark from '../ds/BPLMark.astro'

interface Props { t: Translations; lang: string }
const { t, lang } = Astro.props
const s = t.hero
const contactHref = lang === 'es' ? '/contact?intent=discovery' : '/en/contact?intent=discovery'
---
<section class="hero">
  <!-- Watermark -->
  <div class="hero__watermark" aria-hidden="true">
    <BPLMark size={480} variant="watermark" />
  </div>

  <div class="hero__inner">
    <div class="hero__left">
      <div class="hero__eyebrow">
        <span class="hero__dot" aria-hidden="true"></span>
        {s.eyebrow}
      </div>
      <h1 class="hero__heading" set:html={s.headingHtml} />
      <p class="hero__sub">{s.sub}</p>
      <div class="hero__cta">
        <Button href={contactHref} variant="primary" size="lg">
          {s.cta}
        </Button>
      </div>
      <div class="hero__stats">
        <div class="hero__stat">
          <span class="hero__stat-n">45+</span>
          <span class="hero__stat-l">{s.stats.years}</span>
        </div>
        <div class="hero__stat">
          <span class="hero__stat-n">30+</span>
          <span class="hero__stat-l">{s.stats.projects}</span>
        </div>
        <div class="hero__stat">
          <span class="hero__stat-n">0</span>
          <span class="hero__stat-l">{s.stats.lockins}</span>
        </div>
      </div>
    </div>

    <!-- Large logo on right -->
    <div class="hero__logo" aria-hidden="true">
      <BPLMark size={280} />
    </div>

    <!-- Card disabled - will enable when real sprint data available
    <div class="hero__card" aria-label="Live sprint dashboard example">
      <div class="hero__card-head">
        <div>
          <div class="hero__card-eyebrow">{s.sprintLabel}</div>
          <div class="hero__card-title">{s.sprintMetric}</div>
        </div>
        <span class="bpl-badge bpl-badge--mint">● Live</span>
      </div>
      <div class="hero__card-metric">
        <span class="hero__card-value">4.8</span>
        <span class="hero__card-unit">%</span>
        <span class="hero__card-delta">+182% ↑</span>
      </div>
      <p class="hero__card-sub">{s.sprintSub}</p>
      <svg class="hero__spark" viewBox="0 0 400 120" aria-hidden="true" preserveAspectRatio="none">
        <defs>
          <linearGradient id="sparkFill" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="var(--bpl-mint)" stop-opacity="0.25"/>
            <stop offset="100%" stop-color="var(--bpl-mint)" stop-opacity="0"/>
          </linearGradient>
        </defs>
        <path d="M0,95 L40,92 L80,88 L120,82 L160,78 L200,65 L240,58 L280,42 L320,30 L360,22 L400,12 L400,120 L0,120 Z" fill="url(#sparkFill)"/>
        <path d="M0,95 L40,92 L80,88 L120,82 L160,78 L200,65 L240,58 L280,42 L320,30 L360,22 L400,12" fill="none" stroke="var(--bpl-mint-deep)" stroke-width="2"/>
        <circle cx="400" cy="12" r="4" fill="var(--bpl-mint-deep)"/>
      </svg>
      <div class="hero__card-weeks">
        {s.sprintWeeks.map(w => <span>{w}</span>)}
      </div>
    </div>
    -->
  </div>
</section>

<style>
.hero {
  background: var(--bpl-bg);
  padding: var(--bpl-space-18) var(--bpl-space-8) var(--bpl-space-24);
  position: relative;
  overflow: hidden;
}
.hero__watermark {
  position: absolute;
  right: -160px;
  top: 50%;
  transform: translateY(-50%);
  opacity: 0.5;
  pointer-events: none;
}
.hero__inner {
  max-width: 1280px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--bpl-space-16);
  align-items: center;
}
.hero__eyebrow {
  font: 600 var(--bpl-text-eyebrow)/1 var(--bpl-font-mono);
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--bpl-mint-deep);
  margin-bottom: var(--bpl-space-4);
  display: flex;
  align-items: center;
  gap: var(--bpl-space-2);
}
.hero__dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--bpl-mint-deep);
  animation: pulse 2s infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}
.hero__heading {
  font: 600 var(--bpl-text-hero)/1.02 var(--bpl-font-sans);
  letter-spacing: -0.03em;
  color: var(--bpl-ink);
  margin: var(--bpl-space-6) 0 var(--bpl-space-6);
  line-height: 1.02;
}
.hero__sub {
  font: 400 var(--bpl-text-body-lg)/1.55 var(--bpl-font-sans);
  color: var(--bpl-ink-2);
  margin: 0 0 var(--bpl-space-8);
  max-width: 48ch;
}
.hero__cta {
  margin-bottom: var(--bpl-space-10);
}
.hero__stats {
  display: flex;
  gap: var(--bpl-space-10);
}
.hero__stat {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.hero__stat-n {
  font: 600 var(--bpl-text-h3)/1 var(--bpl-font-sans);
  letter-spacing: -0.02em;
  color: var(--bpl-ink);
}
.hero__stat-l {
  font: 500 var(--bpl-text-mono-sm)/1.4 var(--bpl-font-mono);
  letter-spacing: 0.05em;
  color: var(--bpl-ink-3);
}
.hero__logo {
  display: flex;
  justify-content: center;
  align-items: center;
}

@media (max-width: 900px) {
  .hero__inner { grid-template-columns: 1fr; gap: var(--bpl-space-10); }
  .hero__logo { display: none; }
  .hero__watermark { display: none; }
}
@media (max-width: 600px) {
  .hero { padding: var(--bpl-space-12) var(--bpl-space-5) var(--bpl-space-16); }
  .hero__stats { flex-direction: column; gap: var(--bpl-space-4); }
}
</style>