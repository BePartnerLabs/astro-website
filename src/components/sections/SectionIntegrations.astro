---
import type { Translations } from '../../i18n/es'
interface Props { t: Translations }
const { t } = Astro.props
---
<section class="integrations">
  <div class="integrations__inner">
    <p class="integrations__label">{t.integrations.label}</p>
    <ul class="integrations__list" role="list">
      {t.integrations.items.map(name => <li>{name}</li>)}
    </ul>
  </div>
</section>

<style>
.integrations {
  background: var(--bpl-bg);
  padding: var(--bpl-space-16) var(--bpl-space-8);
  border-top: 1px solid var(--bpl-line);
}
.integrations__inner {
  max-width: 1280px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  gap: var(--bpl-space-10);
  flex-wrap: wrap;
}
.integrations__label {
  font: 500 var(--bpl-text-eyebrow)/1.4 var(--bpl-font-mono);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--bpl-mint-deep);
  flex-shrink: 0;
  margin: 0;
}
.integrations__list {
  display: flex;
  gap: var(--bpl-space-8);
  flex: 1;
  justify-content: flex-start;
  align-items: center;
  flex-wrap: wrap;
  list-style: none;
  margin: 0;
  padding: 0;
}
.integrations__list li {
  font: 500 var(--bpl-text-body)/1 var(--bpl-font-sans);
  color: var(--bpl-ink-2);
}

@media (max-width: 680px) {
  .integrations { padding: var(--bpl-space-12) var(--bpl-space-5); }
  .integrations__inner { flex-direction: column; align-items: flex-start; gap: var(--bpl-space-4); }
  .integrations__list { gap: var(--bpl-space-4); }
}
</style>