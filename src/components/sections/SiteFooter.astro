---
import type { Translations } from '../../i18n/es'
interface Props { t: Translations; lang: string }
const { t, lang } = Astro.props
---
<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__brand">
      <svg width="20" height="20" viewBox="0 0 40 40" fill="none" aria-hidden="true" style="color:var(--bpl-mint)">
        <path d="M20 4C11.163 4 4 11.163 4 20s7.163 16 16 16 16-7.163 16-16S28.837 4 20 4zm0 6a10 10 0 1 1 0 20 10 10 0 0 1 0-20z" fill="currentColor" opacity=".25"/>
        <circle cx="20" cy="20" r="6" fill="currentColor"/>
      </svg>
      <span class="site-footer__wordmark">BePartner</span>
      <span class="site-footer__badge">LABS</span>
      <span class="site-footer__note">{t.footer.note}</span>
    </div>
    <p class="site-footer__rights">{t.footer.rights}</p>
  </div>
</footer>

<style>
.site-footer {
  background: var(--bpl-bg);
  padding: var(--bpl-space-12) var(--bpl-space-8);
  border-top: 1px solid var(--bpl-line);
}
.site-footer__inner {
  max-width: 1280px;
  margin: 0 auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--bpl-space-6);
}
.site-footer__brand {
  display: flex;
  align-items: center;
  gap: var(--bpl-space-2);
}
.site-footer__wordmark {
  font: 600 14px/1 var(--bpl-font-sans);
  letter-spacing: -0.01em;
  color: var(--bpl-ink);
}
.site-footer__badge {
  font: 600 9px/1 var(--bpl-font-mono);
  letter-spacing: 0.16em;
  padding: 2px 5px;
  background: var(--bpl-mint);
  color: var(--bpl-mint-ink);
  border-radius: 3px;
}
.site-footer__note {
  font: 500 11px/1 var(--bpl-font-mono);
  letter-spacing: 0.08em;
  color: var(--bpl-ink-3);
  margin-left: var(--bpl-space-4);
}
.site-footer__rights {
  font: 500 11px/1 var(--bpl-font-mono);
  letter-spacing: 0.06em;
  color: var(--bpl-ink-3);
  margin: 0;
}

@container page (max-width: 680px) {
  .site-footer__inner { flex-direction: column; align-items: flex-start; }
  .site-footer__note { display: none; }
}
</style>
