---
import type { Translations } from '../../i18n/es'
import BPLMark from '../ds/BPLMark.astro'
import ThemeToggle from '../ds/ThemeToggle.astro'
import { getCollection } from 'astro:content'
interface Props { t: Translations; lang: string }
const { t, lang } = Astro.props
const altLang = lang === 'es' ? 'en' : 'es'
const altHref = lang === 'es' ? '/en' : '/'

const navCollection = lang === 'es' ? await getCollection('navEs') : await getCollection('navEn')
const navData = navCollection.find(e => e.id === 'main')?.data
const navItems = navData?.items ?? []
const navCta = navData?.cta ?? { label: t.nav.cta, href: lang === 'es' ? '/contact?intent=general' : '/en/contact?intent=general' }
---
<header class="site-header">
  <div class="site-header__inner">
    <a href={lang === 'es' ? '/' : '/en'} class="site-header__logo" aria-label="Be Partner Labs">
      <BPLMark size={22} />
      <span class="site-header__wordmark">BePartner</span>
      <span class="site-header__badge">LABS</span>
    </a>

    <nav class="site-header__nav" aria-label="Main">
      {navItems.map(item => (
        <a href={item.href} data-nav-link>{item.label}</a>
      ))}
    </nav>

    <div class="site-header__actions">
      <a href={altHref} class="site-header__lang">{altLang.toUpperCase()}</a>
      <ThemeToggle t={t} />
      <a href={navCta.href} class="bpl-btn bpl-btn--primary bpl-btn--sm">{navCta.label}</a>
    </div>

    <button id="nav-toggle" class="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-drawer">
      <svg class="nav-toggle__icon" viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
        <line class="bar bar-1" x1="3" y1="6"  x2="21" y2="6"  stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        <line class="bar bar-2" x1="3" y1="12" x2="21" y2="12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        <line class="bar bar-3" x1="3" y1="18" x2="21" y2="18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
    </button>
  </div>
</header>

<div id="nav-backdrop" class="nav-backdrop"></div>

<nav id="mobile-drawer" class="nav-drawer" aria-label="Mobile menu" aria-hidden="true" style="transform:translateX(100%)">
  <div class="nav-drawer__head">
    <span class="nav-drawer__logo">
      <BPLMark size={18} />
      BePartner<span class="nav-drawer__badge">LABS</span>
    </span>
    <button id="nav-close" class="nav-drawer__close" aria-label="Close menu">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
        <line x1="2" y1="2" x2="16" y2="16"/>
        <line x1="16" y1="2" x2="2" y2="16"/>
      </svg>
    </button>
  </div>

  <ul class="nav-drawer__links" role="list">
    {navItems.map(item => (
      <li><a href={item.href} class="nav-drawer__link">{item.label}</a></li>
    ))}
  </ul>

  <div class="nav-drawer__footer">
    <ThemeToggle t={t} />
    <a href={altHref} class="nav-drawer__lang">{altLang.toUpperCase()}</a>
    <a href={navCta.href} class="bpl-btn bpl-btn--primary" style="justify-content:center">{navCta.label}</a>
  </div>
</nav>

<style>
/* ── Header ── */
.site-header {
  position: sticky;
  top: 0;
  z-index: 50;
  background: color-mix(in srgb, var(--bpl-bg) 85%, transparent);
  backdrop-filter: saturate(180%) blur(16px);
  -webkit-backdrop-filter: saturate(180%) blur(16px);
  border-bottom: 1px solid var(--bpl-line);
}
.site-header__inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 var(--bpl-space-8);
  height: 64px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--bpl-space-6);
}
.site-header__logo {
  display: flex;
  align-items: center;
  gap: var(--bpl-space-2);
  text-decoration: none;
  color: var(--bpl-mint);
  flex-shrink: 0;
}
.site-header__wordmark {
  font: 600 16px/1 var(--bpl-font-sans);
  letter-spacing: -0.01em;
  color: var(--bpl-ink);
}
.site-header__badge {
  font: 600 10px/1 var(--bpl-font-mono);
  letter-spacing: 0.16em;
  padding: 3px 6px;
  background: var(--bpl-mint);
  color: var(--bpl-mint-ink);
  border-radius: 3px;
}
.site-header__nav {
  display: flex;
  gap: var(--bpl-space-7);
}
.site-header__nav a {
  font: 400 14px/1 var(--bpl-font-sans);
  color: var(--bpl-ink-2);
  text-decoration: none;
  transition: color 0.15s;
  position: relative;
}
.site-header__nav a::after {
  content: '';
  position: absolute;
  bottom: -4px;
  left: 0;
  width: 100%;
  height: 1.5px;
  background: var(--bpl-mint);
  border-radius: 999px;
  transform: scaleX(0);
  transform-origin: left center;
  transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
}
.site-header__nav a:hover { color: var(--bpl-ink); }
.site-header__nav :global(a.is-active) {
  color: var(--bpl-ink);
  font-weight: 500;
}
.site-header__nav :global(a.is-active)::after {
  transform: scaleX(1);
}
.site-header__actions {
  display: flex;
  align-items: center;
  gap: var(--bpl-space-3);
  flex-shrink: 0;
}
.site-header__lang {
  font: 500 11px/1 var(--bpl-font-mono);
  letter-spacing: 0.08em;
  color: var(--bpl-ink-2);
  text-decoration: none;
  padding: 0 var(--bpl-space-2);
  height: 32px;
  display: inline-flex;
  align-items: center;
  border: 1px solid var(--bpl-line);
  border-radius: 6px;
}
.site-header__lang:hover { color: var(--bpl-ink); border-color: var(--bpl-ink-3); }

/* ── Hamburger ── */
.nav-toggle {
  display: none;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  padding: 0;
  background: none;
  border: 1px solid var(--bpl-line);
  border-radius: 8px;
  color: var(--bpl-ink);
  cursor: pointer;
  flex-shrink: 0;
}
.nav-toggle__icon { display: block; }

/* Bar animations — use :global so aria-expanded change is picked up outside Astro scope */
:global(.nav-toggle .bar) {
  transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.2s;
  transform-origin: center;
  transform-box: fill-box;
}
:global(.nav-toggle.is-open .bar-1) { transform: translateY(6px) rotate(45deg); }
:global(.nav-toggle.is-open .bar-2) { opacity: 0; transform: scaleX(0); }
:global(.nav-toggle.is-open .bar-3) { transform: translateY(-6px) rotate(-45deg); }

/* ── Backdrop ── */
.nav-backdrop {
  position: fixed;
  inset: 0;
  z-index: 60;
  background: color-mix(in srgb, var(--bpl-ink) 55%, transparent);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.35s cubic-bezier(0.22, 1, 0.36, 1);
}
:global(.nav-backdrop.is-open) {
  opacity: 1;
  pointer-events: auto;
}

/* ── Drawer ── */
.nav-drawer {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 70;
  width: 90vw;
  background: var(--bpl-bg);
  border-radius: 20px 0 0 20px;
  border-left: 1px solid var(--bpl-line);
  box-shadow: none;
  display: flex;
  flex-direction: column;
  padding: var(--bpl-space-6);
  gap: var(--bpl-space-6);
  transform: translateX(100%);
  transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
}
:global(.nav-drawer.is-open) {
  transform: translateX(0);
  box-shadow: -32px 0 80px -8px color-mix(in srgb, var(--bpl-ink) 25%, transparent);
}
.nav-drawer__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.nav-drawer__logo {
  display: flex;
  align-items: center;
  gap: var(--bpl-space-2);
  font: 600 15px/1 var(--bpl-font-sans);
  letter-spacing: -0.01em;
  color: var(--bpl-ink);
}
.nav-drawer__badge {
  font: 600 9px/1 var(--bpl-font-mono);
  letter-spacing: 0.16em;
  padding: 2px 5px;
  background: var(--bpl-mint);
  color: var(--bpl-mint-ink);
  border-radius: 3px;
  margin-left: var(--bpl-space-1);
}
.nav-drawer__close {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: none;
  border: 1px solid var(--bpl-line);
  border-radius: 8px;
  color: var(--bpl-ink-2);
  cursor: pointer;
  transition: color 0.15s, border-color 0.15s;
}
.nav-drawer__close:hover { color: var(--bpl-ink); border-color: var(--bpl-ink-3); }
.nav-drawer__links {
  list-style: none;
  margin: 0;
  padding: var(--bpl-space-4) 0 0;
  border-top: 1px solid var(--bpl-line);
  display: flex;
  flex-direction: column;
  flex: 1;
}
.nav-drawer__link {
  display: block;
  padding: var(--bpl-space-5) 0;
  font: 500 20px/1 var(--bpl-font-sans);
  letter-spacing: -0.01em;
  color: var(--bpl-ink-2);
  text-decoration: none;
  border-bottom: 1px solid var(--bpl-line-soft);
  transition: color 0.15s, padding-left 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}
.nav-drawer__link:hover { color: var(--bpl-ink); padding-left: var(--bpl-space-2); }
.nav-drawer__footer {
  display: flex;
  flex-direction: column;
  gap: var(--bpl-space-3);
  padding-top: var(--bpl-space-4);
  border-top: 1px solid var(--bpl-line);
}
.nav-drawer__lang {
  font: 500 11px/1 var(--bpl-font-mono);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--bpl-ink-3);
  text-decoration: none;
  text-align: center;
  padding: var(--bpl-space-2) 0;
}
.nav-drawer__lang:hover { color: var(--bpl-ink); }

/* ── Responsive ── */
@container page (max-width: 680px) {
  .site-header__inner { padding: 0 var(--bpl-space-5); }
  .site-header__nav   { display: none; }
  .site-header__actions { display: none; }
  .nav-toggle { display: flex; }
}
</style>

<script>
  const toggle   = document.getElementById('nav-toggle')!
  const drawer   = document.getElementById('mobile-drawer')!
  const backdrop = document.getElementById('nav-backdrop')!
  const closeBtn = document.getElementById('nav-close')!

  function open() {
    toggle.classList.add('is-open')
    toggle.setAttribute('aria-expanded', 'true')
    drawer.classList.add('is-open')
    drawer.removeAttribute('aria-hidden')
    backdrop.classList.add('is-open')
    document.body.style.overflow = 'hidden'
  }

  function close() {
    toggle.classList.remove('is-open')
    toggle.setAttribute('aria-expanded', 'false')
    drawer.classList.remove('is-open')
    drawer.setAttribute('aria-hidden', 'true')
    backdrop.classList.remove('is-open')
    document.body.style.overflow = ''
  }

  toggle.addEventListener('click', () => toggle.classList.contains('is-open') ? close() : open())
  closeBtn.addEventListener('click', close)
  backdrop.addEventListener('click', close)
  drawer.querySelectorAll('.nav-drawer__link').forEach(l => l.addEventListener('click', close))
  document.addEventListener('keydown', e => e.key === 'Escape' && close())

  // ── Active nav link via IntersectionObserver ──
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('[data-nav-link]')
  const sectionIds = [...navLinks].map(a => a.getAttribute('href')!.slice(1))
  const sections = sectionIds.map(id => document.getElementById(id)).filter(Boolean) as HTMLElement[]

  const setActive = (id: string) => {
    navLinks.forEach(a => {
      const isActive = a.getAttribute('href') === `#${id}`
      a.classList.toggle('is-active', isActive)
    })
  }

  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) setActive(entry.target.id)
    })
  }, { rootMargin: '-40% 0px -55% 0px', threshold: 0 })

  sections.forEach(s => observer.observe(s))
</script>
