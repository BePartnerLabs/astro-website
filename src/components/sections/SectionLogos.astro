---
import type { Translations } from '../../i18n/es'
interface Props { t: Translations }
const { t } = Astro.props
---
<section class="logos">
  <div class="logos__inner">
    <p class="logos__label">{t.logos.label}</p>
    <ul class="logos__list" role="list">
      {t.logos.items.map(name => <li>{name}</li>)}
    </ul>
  </div>
</section>

<style>
.logos {
  background: var(--bpl-surface-2);
  padding: var(--bpl-space-10) var(--bpl-space-8);
  border-top: 1px solid var(--bpl-line);
  border-bottom: 1px solid var(--bpl-line);
}
.logos__inner {
  max-width: 1280px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  gap: var(--bpl-space-10);
}
.logos__label {
  font: 500 11px/1.4 var(--bpl-font-mono);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--bpl-ink-3);
  flex-shrink: 0;
  max-width: 180px;
  margin: 0;
}
.logos__list {
  display: flex;
  gap: var(--bpl-space-14);
  flex: 1;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  list-style: none;
  margin: 0;
  padding: 0;
}
.logos__list li {
  font: 600 16px/1 var(--bpl-font-sans);
  letter-spacing: 0.04em;
  color: var(--bpl-ink-3);
}
</style>
