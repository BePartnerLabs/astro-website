---
interface Props {
  title: string
  description?: string
  lang?: string
  image?: string
  noIndex?: boolean
}
const {
  title,
  description = 'BePartner Labs — Consultoría estratégica para empresas que buscan construir capacidades internas de producto',
  lang = 'es',
  image = '/og-image.png',
  noIndex = false
} = Astro.props

const siteUrl = 'https://bepartnerlabs.com'
const twitterHandle = '@BePartnerLabs'
---
<!doctype html>
<html lang={lang} data-theme="dark">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-3QW3ZRWVY9"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-3QW3ZRWVY9');
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      (function(){
        var t = localStorage.getItem('theme');
        if (t !== 'light' && t !== 'dark') {
          t = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        }
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#5FCB9F" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-itunes-app" content="app-id=1551344070" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={twitterHandle} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image.startsWith('http') ? image : `${siteUrl}${image}`} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${siteUrl}${Astro.url.pathname}`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image.startsWith('http') ? image : `${siteUrl}${image}`} />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
    <title>{title}</title>
    <link rel="canonical" href={`${siteUrl}${Astro.url.pathname}`} />
    {description && <meta name="description" content={description} />}
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="apple-intelligence-supports-summarization" content="true" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "BePartner Labs",
      "url": siteUrl,
      "logo": `${siteUrl}/favicon.svg`,
      "sameAs": [
        "https://twitter.com/BePartnerLabs",
        "https://linkedin.com/company/bepartnerlabs"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "hello@bepartnerlabs.com",
        "contactType": "customer service"
      }
    })} />
  </head>
  <body>
    <a href="#main-content" class="bpl-skip-link">Skip to content</a>
    <div id="bpl-progress" aria-hidden="true"></div>
    <slot />
    <script is:inline>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js');
      }
    </script>
    <script is:inline>
      (function () {
        var visibleSince = {};
        var accumulated = {};

        function flush(name) {
          if (!visibleSince[name]) return;
          var elapsed = Math.round((Date.now() - visibleSince[name]) / 1000);
          accumulated[name] = (accumulated[name] || 0) + elapsed;
          visibleSince[name] = null;
        }

        function fireEvent(name) {
          var total = accumulated[name] || 0;
          if (total < 1) return;
          if (typeof gtag === 'function') {
            gtag('event', 'section_engagement', { section_name: name, seconds_visible: total });
          }
        }

        document.addEventListener('DOMContentLoaded', function () {
          var sections = document.querySelectorAll('[data-section]');
          if (!sections.length || !('IntersectionObserver' in window)) return;

          var observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              var name = entry.target.getAttribute('data-section');
              if (entry.isIntersecting) {
                visibleSince[name] = Date.now();
              } else {
                flush(name);
              }
            });
          }, { threshold: 0.25 });

          sections.forEach(function (el) { observer.observe(el); });

          document.addEventListener('visibilitychange', function () {
            if (document.hidden) {
              sections.forEach(function (el) { flush(el.getAttribute('data-section')); });
            } else {
              sections.forEach(function (el) {
                var name = el.getAttribute('data-section');
                var rect = el.getBoundingClientRect();
                var inView = rect.top < window.innerHeight && rect.bottom > 0;
                if (inView) visibleSince[name] = Date.now();
              });
            }
          });

          window.addEventListener('beforeunload', function () {
            sections.forEach(function (el) {
              var name = el.getAttribute('data-section');
              flush(name);
              fireEvent(name);
            });
          });
        });
      })();
    </script>
    <script is:inline>
      (function () {
        var milestones = [30, 60, 120];
        var fired = {};
        milestones.forEach(function (seconds) {
          setTimeout(function () {
            if (fired[seconds]) return;
            fired[seconds] = true;
            if (typeof gtag === 'function') {
              gtag('event', 'dwell_time', { seconds: seconds });
            }
          }, seconds * 1000);
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/tokens.css';
  @import '../styles/animations.css';

  *, *::before, *::after { box-sizing: border-box; }

  body {
    margin: 0;
    container-type: inline-size;
    container-name: page;
  }
</style>
