---
interface Props {
  title: string
  description?: string
  lang?: string
  image?: string
  noIndex?: boolean
}
const {
  title,
  description = 'BePartner Labs — Consultoría estratégica para empresas que buscan construir capacidades internas de producto',
  lang = 'es',
  image = '/og-image.png',
  noIndex = false
} = Astro.props

const siteUrl = 'https://bepartnerlabs.com'
const twitterHandle = '@BePartnerLabs'
---
<!doctype html>
<html lang={lang} data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      (function(){
        var t = localStorage.getItem('theme');
        if (t !== 'light' && t !== 'dark') {
          t = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        }
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#5FCB9F" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-itunes-app" content="app-id=1551344070" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={twitterHandle} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image.startsWith('http') ? image : `${siteUrl}${image}`} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${siteUrl}${Astro.url.pathname}`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image.startsWith('http') ? image : `${siteUrl}${image}`} />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="apple-intelligence-supports-summarization" content="true" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "BePartner Labs",
      "url": siteUrl,
      "logo": `${siteUrl}/favicon.svg`,
      "sameAs": [
        "https://twitter.com/BePartnerLabs",
        "https://linkedin.com/company/bepartnerlabs"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "hello@bepartnerlabs.com",
        "contactType": "customer service"
      }
    })} />
  </head>
  <body>
    <a href="#main-content" class="bpl-skip-link">Skip to content</a>
    <div id="bpl-progress" aria-hidden="true"></div>
    <slot />
    <script is:inline>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js');
      }
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/tokens.css';
  @import '../styles/animations.css';

  *, *::before, *::after { box-sizing: border-box; }

  body {
    margin: 0;
    container-type: inline-size;
    container-name: page;
  }
</style>
